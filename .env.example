# MME · Agent 评测平台 —— 环境变量示例。复制为 .env 并按需填写（.env 不要提交 git）。

# --- 数据库 / 路径（可选，留空走默认本地 SQLite） ---
# MEDEVAL_DATABASE_URL=sqlite:////abs/path/medeval_platform.db
# MEDEVAL_CONFIG_PATH=config.yaml
# MEDEVAL_UPLOADS_DIR=uploads/benchmarks
# MEDEVAL_OUTPUTS_DIR=outputs
# MEDEVAL_MAX_CONCURRENT_JOBS=2
# MEDEVAL_MAX_UPLOAD_BYTES=5242880
# 运行环境：development（默认）/ test / production。production 时禁止默认 SESSION_SECRET，且 cookie 加 Secure。
# MEDEVAL_ENV=development

# --- 飞书 SSO 登录 / per-user 导出 ---
# 自建应用凭证（飞书开发者后台 > 凭证与基础信息）。配齐后平台才强制登录。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 回调地址，必须与飞书后台「重定向 URL」完全一致。
# 开发态默认前端同源（vite 把 /api 代理到后端）。
FEISHU_REDIRECT_URI=http://localhost:5173/api/auth/feishu/callback
# 申请的权限。offline_access 必填（用于拿 refresh_token，免重复授权）。
FEISHU_SCOPES=offline_access contact:user.base:readonly drive:drive
# 登录成功后回跳的前端地址。
FRONTEND_URL=http://localhost:5173
# 会话 cookie 签名密钥（生产必须改成随机强密钥）。
SESSION_SECRET=please-change-me
# 会话有效期（秒），默认 7 天。
SESSION_TTL_SECONDS=604800

# --- Langfuse 全链路追踪（默认开启 · 自托管；参见 config.yaml observability.langfuse） ---
# 不填凭据 = 自动 no-op、不报错、前端隐藏「追踪链路」入口。需先 pip install -e ".[langfuse]"。
# 自托管实例地址（也可在 config.yaml 的 observability.langfuse.host 配置）。
# LANGFUSE_HOST=https://langfuse.your-company.com
# 项目凭据（自托管后台 > 项目 > Settings > API Keys）。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
