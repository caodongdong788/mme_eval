# Docker Compose 部署示例 — 复制为 .env 后按需修改（勿提交 git）。
# 用法：cp .env.docker.example .env && docker compose up -d --build

# --- 运行环境（生产必改） ---
MEDEVAL_ENV=production
# 必须改成随机强密钥（32+ 字符）；仍为默认值时 production 启动会 abort。
SESSION_SECRET=please-change-me-to-a-long-random-secret

# --- 数据库（Compose 内置 Postgres，与下方 db 服务账号一致） ---
MEDEVAL_DATABASE_URL=postgresql+psycopg2://medeval:medeval@db:5432/medeval

# --- 持久化路径（容器内；已通过 volume mme-data 挂载） ---
MEDEVAL_OUTPUTS_DIR=/data/outputs
MEDEVAL_UPLOADS_DIR=/data/uploads/benchmarks
MEDEVAL_CONFIG_PATH=/app/config.yaml

# --- 并发 ---
MEDEVAL_MAX_CONCURRENT_JOBS=2
MEDEVAL_MAX_UPLOAD_BYTES=5242880
MEDEVAL_LOG_LEVEL=INFO

# --- 访问地址（公网部署改成 https://你的域名；内网可 http://内网IP:8000） ---
FRONTEND_URL=http://localhost:8000

# --- 飞书 SSO（公网/需登录时必填；内网可信环境可留空 = 不强制登录） ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8000/api/auth/feishu/callback
FEISHU_SCOPES=offline_access contact:user.base:readonly drive:drive
SESSION_TTL_SECONDS=604800

# --- Postgres（与 docker-compose.yml db 服务一致） ---
POSTGRES_USER=medeval
POSTGRES_PASSWORD=medeval
POSTGRES_DB=medeval

# --- Langfuse（可选） ---
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
